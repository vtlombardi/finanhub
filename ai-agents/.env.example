# ==========================================
# Configurações do AI-Worker (BullMQ Node)
# ==========================================

# Banco de Dados Analítico (O Worker altera a base da plataforma diretamente)
DATABASE_URL="postgresql://finan_dev:dev_pass@localhost:5432/finanhub_db?schema=public"

# Comunicação Fila Redis
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379

# Credenciais e Engine da OpenAI
OPENAI_API_KEY="sk-XXXXXXXXXXXXXXXX"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_TEMPERATURE="0.2"
OPENAI_MAX_RETRIES="3"
OPENAI_TIMEOUT_MS="20000"
