# Database
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT - use a strong random secret (min 32 chars)
JWT_SECRET=your-strong-random-secret-here

# Server
PORT=3000

# Email (Nodemailer)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your@email.com
MAIL_PASS=your-smtp-password
MAIL_FROM=security@finanhub.com.br

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# OpenAI (for AI agents)
OPENAI_API_KEY=sk-...
