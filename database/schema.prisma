generator client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String              @id @default(uuid())
  slug             String              @unique
  name             String
  document         String?             @unique
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  ads              Ad[]
  aiJobs           AiJob[]
  auditLogs        AuditLog[]
  categories       Category[]
  categoryAttrs    CategoryAttribute[]
  chatThreads      ChatThread[]
  companies        Company[]
  dailyMetrics     DailyMetric[]
  dataRoomDocs     DataRoomDocument[]
  dataRoomRequests DataRoomRequest[]
  leads            Lead[]
  listings         Listing[]
  metrics          Metric[]
  plans            Plan[]
  subscriptions    Subscription[]
  users            User[]

  @@index([slug])
}

model User {
  id                      String             @id @default(uuid())
  tenantId                String
  email                   String
  passwordHash            String
  fullName                String
  role                    Role               @default(USER)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  isEmailVerified         Boolean            @default(false)
  verificationCode        String?
  verificationCodeExpires DateTime?
  resetPasswordCode       String?
  resetPasswordExpires    DateTime?
  auditLogs               AuditLog[]
  chatMessages            ChatMessage[]
  chatParticipants        ChatParticipant[]
  companyMembers          CompanyMember[]
  dataRoomRequests        DataRoomRequest[]
  favorites               Favorite[]
  leads                   Lead[]
  listings                Listing[]
  moderationActions       ModerationAction[] @relation("moderationActions")
  notifications           Notification[]
  proposals               Proposal[]
  tenant                  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
}

model Company {
  id         String          @id @default(uuid())
  tenantId   String
  slug       String
  name       String
  tradeName  String?
  document   String?
  isVerified Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members    CompanyMember[]
  listings   Listing[]

  @@unique([tenantId, slug])
}

model CompanyMember {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

model Category {
  id          String              @id @default(uuid())
  tenantId    String
  slug        String
  name        String
  description String?
  iconClass   String?
  createdAt   DateTime            @default(now())
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attributes  CategoryAttribute[]
  listings    Listing[]

  @@unique([tenantId, slug])
}

model CategoryAttribute {
  id         String                  @id @default(uuid())
  tenantId   String
  categoryId String
  name       String
  label      String
  type       String
  isRequired Boolean                 @default(false)
  category   Category                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  values     ListingAttributeValue[]

  @@unique([categoryId, name])
}

model Listing {
  id                  String                  @id @default(uuid())
  tenantId            String
  companyId           String
  categoryId          String
  slug                String
  title               String
  description         String
  price               Decimal?                @db.Decimal(15, 2)
  city                String?
  state               String?
  neighborhood        String?
  addressLine1        String?
  addressLine2        String?
  zipCode             String?
  country             String?
  addressReference    String?
  email               String?
  websiteUrl          String?
  phonePrimary        String?
  phoneSecondary      String?
  facebookUrl         String?
  instagramUrl        String?
  twitterUrl          String?
  linkedinUrl         String?
  tiktokUrl           String?
  investmentValue     Decimal?                @db.Decimal(15, 2)
  seoTitle            String?
  seoKeywords         String?
  seoDescription      String?
  logoUrl             String?
  videoUrl            String?
  videoDescription    String?
  status              ListingStatus           @default(DRAFT)
  viewCount           Int                     @default(0)
  isFeatured          Boolean                 @default(false)
  featuredUntil       DateTime?
  featuredPriority    Int                     @default(0)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  ownerId             String?
  isTest              Boolean                 @default(false)
  seedTag             String?
  annualRevenue       Decimal?                @db.Decimal(15, 2)
  avgTicket           Decimal?                @db.Decimal(15, 2)
  buyerProfile        String?
  clientBaseCount     Int?
  confidentialityNote String?
  ebitdaMargin        Decimal?                @db.Decimal(5, 2)
  marketTime          Int?
  nextSteps           String?
  operationStructure  String?
  reasonForSale       String?
  revenueModel        String?
  subtitle            String?
  valuationMethod     String?
  ebitda              Decimal?                @db.Decimal(15, 2)
  employeesCount      Int?
  aiInsights          AiInsight[]
  businessHours       BusinessHour[]
  chatThreads         ChatThread[]
  dataRoomDocs        DataRoomDocument[]
  dataRoomRequests    DataRoomRequest[]
  favorites           Favorite[]
  leads               Lead[]
  category            Category                @relation(fields: [categoryId], references: [id])
  company             Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner               User?                   @relation(fields: [ownerId], references: [id])
  tenant              Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attrValues          ListingAttributeValue[]
  features            ListingFeature[]
  media               ListingMedia[]
  metrics             Metric[]
  moderationActions   ModerationAction[]

  @@unique([tenantId, slug])
  @@index([tenantId, status, createdAt])
  @@index([categoryId, status])
}

model ListingFeature {
  id        String   @id @default(uuid())
  listingId String
  name      String
  iconClass String?
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model BusinessHour {
  id        String   @id @default(uuid())
  listingId String
  dayOfWeek Int
  openTime  String
  closeTime String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingMedia {
  id        String   @id @default(uuid())
  listingId String
  url       String
  mediaType String
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model ListingAttributeValue {
  id          String            @id @default(uuid())
  listingId   String
  attributeId String
  valueStr    String?
  valueNum    Decimal?          @db.Decimal(15, 2)
  valueBool   Boolean?
  attribute   CategoryAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  listing     Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, attributeId])
}

model Lead {
  id                  String       @id @default(uuid())
  tenantId            String
  listingId           String
  investorId          String
  message             String
  score               Int?
  intentLevel         IntentLevel?
  aiClassification    String?
  aiReasonSummary     String?
  aiRecommendedAction String?
  aiProcessedAt       DateTime?
  aiError             String?
  createdAt           DateTime     @default(now())
  status              LeadStatus   @default(NEW)
  internalNotes       String?
  investor            User         @relation(fields: [investorId], references: [id], onDelete: Cascade)
  listing             Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenant              Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  proposals           Proposal[]

  @@index([tenantId, investorId])
  @@index([listingId])
}

model Proposal {
  id           String         @id @default(uuid())
  leadId       String
  investorId   String
  valueOffered Decimal        @db.Decimal(15, 2)
  conditions   String?
  status       ProposalStatus @default(OPEN)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  investor     User           @relation(fields: [investorId], references: [id], onDelete: Cascade)
  lead         Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(uuid())
  listingId String
  userId    String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
}

model ChatThread {
  id           String            @id @default(uuid())
  tenantId     String
  listingId    String
  leadId       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  messages     ChatMessage[]
  participants ChatParticipant[]
  listing      Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model ChatParticipant {
  id       String     @id @default(uuid())
  threadId String
  userId   String
  joinedAt DateTime   @default(now())
  thread   ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
}

model ChatMessage {
  id        String     @id @default(uuid())
  threadId  String
  senderId  String
  body      String
  isRead    Boolean    @default(false)
  createdAt DateTime   @default(now())
  sender    User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model ModerationAction {
  id             String   @id @default(uuid())
  listingId      String
  moderatorId    String
  action         String
  reason         String?
  previousStatus String?
  newStatus      String?
  createdAt      DateTime @default(now())
  listing        Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  moderator      User     @relation("moderationActions", fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Plan {
  id                  String         @id @default(uuid())
  tenantId            String?
  tier                PlanTier
  name                String
  description         String?
  price               Decimal        @db.Decimal(15, 2)
  priceYearly         Decimal?       @db.Decimal(15, 2)
  currency            String         @default("BRL")
  isPublic            Boolean        @default(true)
  maxListings         Int            @default(1)
  maxLeadsPerMonth    Int            @default(10)
  maxFeaturedListings Int            @default(0)
  hasAiQualification  Boolean        @default(false)
  hasChat             Boolean        @default(false)
  hasPrioritySupport  Boolean        @default(false)
  hasAnalytics        Boolean        @default(false)
  hasApiAccess        Boolean        @default(false)
  hasCustomBranding   Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  tenant              Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions       Subscription[]
}

model Subscription {
  id            String    @id @default(uuid())
  tenantId      String
  planId        String
  startDate     DateTime  @default(now())
  endDate       DateTime?
  isActive      Boolean   @default(true)
  canceledAt    DateTime?
  cancelReason  String?
  billingCycle  String    @default("MONTHLY")
  externalId    String?
  lastPaymentAt DateTime?
  nextBillingAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  creditBalance Decimal   @default(0) @db.Decimal(15, 2)
  plan          Plan      @relation(fields: [planId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, entityType])
}

model AiJob {
  id          String      @id @default(uuid())
  tenantId    String
  traceId     String      @unique
  jobName     String
  status      AiJobStatus @default(PENDING)
  payload     Json
  result      Json?
  error       String?
  createdAt   DateTime    @default(now())
  completedAt DateTime?
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Ad {
  id        String     @id @default(uuid())
  tenantId  String?
  title     String
  imageUrl  String?
  linkUrl   String
  position  AdPosition
  isActive  Boolean    @default(true)
  startsAt  DateTime   @default(now())
  endsAt    DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant?    @relation(fields: [tenantId], references: [id])

  @@index([position, isActive, startsAt])
}

model AiInsight {
  id               String   @id @default(uuid())
  listingId        String
  scamProbability  Decimal? @db.Decimal(5, 4)
  recommendedTitle String?
  flags            String[]
  createdAt        DateTime @default(now())
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Metric {
  id        String   @id @default(uuid())
  tenantId  String
  listingId String?
  type      String
  value     Float    @default(1.0)
  metadata  Json?
  createdAt DateTime @default(now())
  listing   Listing? @relation(fields: [listingId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, createdAt])
}

model DailyMetric {
  id        String   @id @default(uuid())
  tenantId  String
  date      DateTime @db.Date
  type      String
  value     Int      @default(0)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date, type])
}

model DataRoomDocument {
  id        String   @id @default(uuid())
  tenantId  String
  listingId String
  name      String
  url       String
  mediaType String   @default("document")
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model DataRoomRequest {
  id         String         @id @default(uuid())
  tenantId   String
  listingId  String
  investorId String
  status     DataRoomStatus @default(PENDING)
  message    String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  investor   User           @relation(fields: [investorId], references: [id], onDelete: Cascade)
  listing    Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([listingId, investorId])
  @@index([tenantId, status])
}

enum LeadStatus {
  NEW
  UNDER_REVIEW
  IN_CONTACT
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum Role {
  USER
  ADMIN
  OWNER
}

enum ListingStatus {
  DRAFT
  PENDING_AI_REVIEW
  ACTIVE
  INACTIVE
  FLAGGED
  SUSPENDED
  CLOSED
}

enum ProposalStatus {
  OPEN
  ACCEPTED
  REJECTED
  COUNTER_OFFER
  WITHDRAWN
}

enum PlanTier {
  FREE
  BASIC
  PRO
  ENTERPRISE
  ESSENTIAL
  PREMIUM
  BUSINESS
  CORPORATE_ELITE
  BASE
  PROFESSIONAL
  ELITE
}

enum AdPosition {
  LEADERBOARD
  MOBILE_BANNER
  SIDEBAR
}

enum AiJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum IntentLevel {
  LOW
  MEDIUM
  HIGH
}

enum DataRoomStatus {
  PENDING
  APPROVED
  REJECTED
}
