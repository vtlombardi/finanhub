# =============================================================================
# FINANHUB - Variáveis de Produção
# Copie este arquivo para .env.prod e preencha os valores reais.
# NUNCA suba .env.prod para o git.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=finanhub
POSTGRES_PASSWORD=troque-por-senha-forte
POSTGRES_DB=finanhub_prod
DATABASE_URL=postgresql://finanhub:troque-por-senha-forte@db:5432/finanhub_prod

# --- Backend ---
PORT=3000
NODE_ENV=production

# JWT: gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=gere-um-secret-de-minimo-48-chars-aqui

# CORS: domínios permitidos separados por vírgula
ALLOWED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Email (Nodemailer) ---
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USER=noreply@seudominio.com.br
SMTP_PASS=senha-do-smtp

# --- OpenAI (AI Agents) ---
OPENAI_API_KEY=sk-proj-...

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=https://seudominio.com.br/api
